function updateFlashcard(i) {
  const day = DAYS[i];
  const cards = day.dialogue;
  const idx = fcIdx[i];
  const card = cards[idx];
  document.getElementById(`fc-en-${i}`).textContent = card.en;
  document.getElementById(`fc-spk-${i}`).textContent = card.speaker;
  document.getElementById(`fc-vn-${i}`).textContent = card.vn;
  document.getElementById(`fc-count-${i}`).textContent = `${idx + 1} / ${cards.length}`;
  fcFlipped[i] = false;
  document.getElementById(`fc-${i}`).classList.remove('flipped');
}

function flipCard(i) {
  fcFlipped[i] = !fcFlipped[i];
  document.getElementById(`fc-${i}`).classList.toggle('flipped', fcFlipped[i]);
}
function fcNext(i) {
  const max = DAYS[i].dialogue.length - 1;
  if (fcIdx[i] < max) { fcIdx[i]++; updateFlashcard(i); }
}
function fcPrev(i) {
  if (fcIdx[i] > 0) { fcIdx[i]--; updateFlashcard(i); }
}

