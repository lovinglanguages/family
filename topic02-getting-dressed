let currentView = 'day'; 

function openDay(i) {
  currentView = 'day';
  document.querySelectorAll('.day-panel').forEach(p => p.classList.remove('active'));
  const fs = document.getElementById('panel-fullscript');
  if (fs) fs.classList.remove('active');
  document.getElementById(`panel-${i}`).classList.add('active');
  currentDay = i;
  renderNav();
  const nav = document.getElementById('daysNav');
  const pill = nav.children[i];
  if (pill) pill.scrollIntoView({ behavior:'smooth', block:'nearest', inline:'center' });
}

function openFullScript() {
  currentView = 'fullscript';
  document.querySelectorAll('.day-panel').forEach(p => p.classList.remove('active'));
  const fs = document.getElementById('panel-fullscript');
  if (fs) {
    fs.classList.add('active');
    DAYS.forEach((_, i) => {
      const num = fs.querySelector(`#fschev-${i}`)?.closest('.fs-day-block')?.querySelector('.fs-day-num');
      if (num) {
        if (doneDays.includes(i)) num.classList.add('done-num');
        else num.classList.remove('done-num');
      }
    });
  }
  renderNav();
  const nav = document.getElementById('daysNav');
  nav.lastElementChild?.scrollIntoView({ behavior:'smooth', block:'nearest', inline:'center' });
}

function toggleFsDay(i) {
  const dlg  = document.getElementById(`fsdlg-${i}`);
  const chev = document.getElementById(`fschev-${i}`);
  const isOpen = dlg.classList.contains('open');
  dlg.classList.toggle('open', !isOpen);
  chev.classList.toggle('open', !isOpen);
}

function switchMode(dayIdx, mode, btn) {
  const panel = document.getElementById(`panel-${dayIdx}`);
  panel.querySelectorAll('.mode-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  panel.querySelectorAll('.mode-content').forEach(c => c.classList.remove('active'));
  document.getElementById(`mode-${dayIdx}-${mode}`).classList.add('active');
}

