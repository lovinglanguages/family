<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Topic 02 – Getting Dressed · Lani Be A Gift</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">

<script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-firestore-compat.js"></script>

<style>
  :root {
    --cream: #FBF7F0; --warm-white: #FFFCF7; --blush: #F5E6D8; --rose: #E8C4A8;
    --terracotta: #C9764A; --terra-deep: #A0552E;
    --sage: #7A9E87; --sage-light: #C8DDD0; --sage-deep: #4A7259;
    --sky: #8BB8D4; --sky-light: #D4E8F3;
    --lavender: #C4B5D4; --lavender-light: #EDE8F5;
    --sunny: #F2C94C; --sunny-light: #FBF0C4;
    --coral: #E8856A; --coral-light: #FAD8CF;
    --ink: #2C2416; --ink-soft: #5C4E3A; --ink-muted: #8C7E6A;
    --border: rgba(44,36,22,0.12);
    --radius: 16px; --radius-sm: 10px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'DM Sans',sans-serif; background:var(--cream); color:var(--ink); min-height:100vh; }

  /* ── HEADER ── */
  header {
    background:var(--warm-white); border-bottom:1px solid var(--border);
    padding:0 20px; height:56px;
    display:flex; align-items:center; justify-content:space-between;
    position:sticky; top:0; z-index:100;
  }
  .logo { font-family:'Playfair Display',serif; font-size:18px; color:var(--terracotta); }
  .logo span { font-style:italic; }
  .home-btn {
    padding:6px 14px; border-radius:8px; border:1px solid var(--border);
    font-size:12px; color:var(--ink-muted); background:none; cursor:pointer;
    font-family:'DM Sans',sans-serif; text-decoration:none;
    display:flex; align-items:center; gap:5px;
  }
  .home-btn:hover { background:var(--blush); }

  /* ── LOADING OVERLAY ── */
  #loading-overlay { position: fixed; inset: 0; background: var(--cream); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 2000; }
  .spinner { width: 40px; height: 40px; border: 3px solid var(--blush); border-top-color: var(--terracotta); border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 15px; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── TOPIC HERO ── */
  .topic-hero {
    background:var(--warm-white); padding:28px 20px 20px;
    border-bottom:1px solid var(--border);
  }
  .topic-eyebrow { font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--terracotta); margin-bottom:6px; }
  .topic-title { font-family:'Playfair Display',serif; font-size:26px; color:var(--ink); margin-bottom:4px; }
  .topic-title em { color:var(--terracotta); font-style:italic; }
  .topic-vn { font-size:13px; color:var(--ink-muted); }

  /* ── DAYS NAV ── */
  .days-nav {
    display:flex; gap:8px; padding:16px 20px;
    overflow-x:auto; -webkit-overflow-scrolling:touch;
    background:var(--warm-white); border-bottom:1px solid var(--border);
    scrollbar-width:none;
  }
  .days-nav::-webkit-scrollbar { display:none; }
  .day-pill {
    flex-shrink:0; width:44px; height:44px; border-radius:50%;
    border:1px solid var(--border); background:var(--warm-white);
    font-size:13px; font-weight:500; cursor:pointer;
    transition:all 0.2s; display:flex; flex-direction:column;
    align-items:center; justify-content:center; gap:1px;
    font-family:'DM Sans',sans-serif; color:var(--ink-muted);
  }
  .day-pill:hover { background:var(--blush); border-color:var(--rose); }
  .day-pill.active { background:var(--terracotta); color:white; border-color:var(--terracotta); }
  .day-pill.done { background:var(--sage-light); color:var(--sage-deep); border-color:var(--sage); }
  .day-pill-num { font-size:14px; font-weight:500; line-height:1; }
  .day-pill-check { font-size:9px; line-height:1; }

  /* ── DAY PANEL ── */
  .day-panel { display:none; }
  .day-panel.active { display:block; }

  /* ── DAY HEADER ── */
  .day-header {
    padding:20px 20px 16px;
    background:var(--warm-white); border-bottom:1px solid var(--border);
  }
  .day-num-label { font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--ink-muted); margin-bottom:4px; }
  .day-title { font-family:'Playfair Display',serif; font-size:20px; color:var(--ink); margin-bottom:6px; }
  .day-dialogue-preview {
    display:flex; flex-direction:column; gap:6px;
    padding:14px 16px; background:var(--blush);
    border-radius:var(--radius-sm); margin-top:10px;
  }
  .dialogue-line { font-size:13px; line-height:1.5; }
  .dialogue-line strong { color:var(--terracotta); }
  .dialogue-line .vn { color:var(--ink-muted); font-style:italic; font-size:12px; }

  /* ── MODE TABS ── */
  .mode-tabs {
    display:flex; gap:6px; padding:14px 20px;
    overflow-x:auto; background:var(--warm-white);
    border-bottom:1px solid var(--border); scrollbar-width:none;
  }
  .mode-tabs::-webkit-scrollbar { display:none; }
  .mode-tab {
    flex-shrink:0; padding:7px 14px; border-radius:99px;
    border:1px solid var(--border); font-size:12px;
    font-family:'DM Sans',sans-serif; cursor:pointer;
    transition:all 0.2s; background:var(--warm-white);
    color:var(--ink-soft); white-space:nowrap;
  }
  .mode-tab:hover { background:var(--blush); }
  .mode-tab.active { background:var(--terracotta); color:white; border-color:var(--terracotta); }

  /* ── MODE CONTENT ── */
  .mode-content { padding:20px; display:none; }
  .mode-content.active { display:block; }

  /* ── FLASHCARD ── */
  .fc-wrap { perspective:1000px; height:240px; margin-bottom:20px; }
  .fc {
    width:100%; height:100%; position:relative;
    transform-style:preserve-3d; transition:transform 0.5s; cursor:pointer;
  }
  .fc.flipped { transform:rotateY(180deg); }
  .fc-front, .fc-back {
    position:absolute; inset:0; backface-visibility:hidden;
    border-radius:var(--radius); display:flex; flex-direction:column;
    align-items:center; justify-content:center; padding:24px; text-align:center;
  }
  .fc-front { background:var(--warm-white); border:1px solid var(--border); }
  .fc-back { background:var(--terracotta); transform:rotateY(180deg); }
  .fc-en { font-family:'Playfair Display',serif; font-size:22px; color:var(--ink); margin-bottom:6px; }
  .fc-speaker { font-size:12px; color:var(--ink-muted); letter-spacing:1px; text-transform:uppercase; }
  .fc-hint { font-size:12px; color:var(--ink-muted); margin-top:14px; }
  .fc-vn { font-family:'Playfair Display',serif; font-size:20px; color:white; margin-bottom:8px; }
  .fc-nav { display:flex; align-items:center; justify-content:center; gap:16px; }
  .fc-btn {
    width:42px; height:42px; border-radius:50%; border:1px solid var(--border);
    background:var(--warm-white); font-size:16px; cursor:pointer;
    display:flex; align-items:center; justify-content:center; transition:all 0.2s;
  }
  .fc-btn:hover { background:var(--blush); }
  .fc-count { font-size:13px; color:var(--ink-muted); min-width:60px; text-align:center; }

  /* ── VOCAB ── */
  .vocab-card {
    background:var(--warm-white); border:1px solid var(--border);
    border-radius:var(--radius); overflow:hidden; margin-bottom:14px;
  }
  .vocab-top {
    padding:14px 18px 12px; border-bottom:1px solid var(--border);
    display:flex; align-items:baseline; gap:10px; flex-wrap:wrap;
  }
  .vocab-word { font-family:'Playfair Display',serif; font-size:20px; color:var(--ink); }
  .vocab-phonetic { font-family:'DM Mono',monospace; font-size:12px; color:var(--ink-muted); }
  .vocab-speaker-badge {
    margin-left:auto; padding:3px 10px; border-radius:99px;
    font-size:11px; background:var(--blush); color:var(--terracotta); font-weight:500;
  }
  .vocab-body { padding:14px 18px; }
  .vocab-meaning { font-size:15px; color:var(--ink); font-weight:500; margin-bottom:10px; }
  .vocab-row { display:flex; gap:8px; margin-bottom:7px; font-size:13px; line-height:1.5; }
  .vr-label {
    color:var(--terracotta); font-weight:500; min-width:80px; flex-shrink:0;
    font-size:11px; text-transform:uppercase; letter-spacing:0.5px; padding-top:1px;
  }
  .vr-val { color:var(--ink-soft); }
  .vr-vn { color:var(--ink-muted); font-size:12px; font-style:italic; margin-top:2px; }
  .speak-btn {
    display:inline-flex; align-items:center; gap:5px;
    padding:5px 12px; border-radius:99px; border:1px solid var(--border);
    background:var(--warm-white); font-size:12px; color:var(--ink-muted);
    cursor:pointer; margin-top:10px; font-family:'DM Sans',sans-serif; transition:all 0.2s;
  }
  .speak-btn:hover { background:var(--blush); }

  /* ── QUIZ ── */
  .quiz-q-card {
    background:var(--warm-white); border:1px solid var(--border);
    border-radius:var(--radius); padding:22px 20px; margin-bottom:16px;
  }
  .quiz-q-num { font-size:11px; color:var(--ink-muted); margin-bottom:6px; letter-spacing:1px; text-transform:uppercase; }
  .quiz-q-text { font-family:'Playfair Display',serif; font-size:22px; color:var(--ink); margin-bottom:4px; }
  .quiz-q-inst { font-size:12px; color:var(--ink-muted); }
  .quiz-opts { display:flex; flex-direction:column; gap:8px; margin-bottom:14px; }
  .quiz-opt {
    padding:13px 16px; border-radius:var(--radius-sm);
    border:1px solid var(--border); background:var(--warm-white);
    cursor:pointer; font-size:14px; color:var(--ink); transition:all 0.2s;
    text-align:left; font-family:'DM Sans',sans-serif;
  }
  .quiz-opt:hover { background:var(--blush); border-color:var(--rose); }
  .quiz-opt.correct { background:var(--sage-light); border-color:var(--sage); color:var(--sage-deep); }
  .quiz-opt.wrong { background:var(--coral-light); border-color:var(--coral); color:#7A2E1A; }
  .quiz-fb {
    padding:13px 16px; border-radius:var(--radius-sm);
    font-size:13px; line-height:1.5; display:none; margin-bottom:12px;
  }
  .quiz-fb.show { display:block; }
  .quiz-fb.ok { background:var(--sage-light); color:var(--sage-deep); }
  .quiz-fb.nope { background:var(--coral-light); color:#7A2E1A; }
  .quiz-next {
    width:100%; padding:13px; border-radius:var(--radius-sm);
    border:none; background:var(--terracotta); color:white;
    font-size:14px; font-family:'DM Sans',sans-serif; font-weight:500;
    cursor:pointer; transition:all 0.2s;
  }
  .quiz-next:hover { background:var(--terra-deep); }
  .quiz-next:disabled { opacity:0.35; cursor:default; }

  /* ── DICTATION ── */
  .dict-card {
    background:var(--warm-white); border:1px solid var(--border);
    border-radius:var(--radius); padding:24px 20px; text-align:center; margin-bottom:16px;
  }
  .dict-blanks { font-family:'DM Mono',monospace; font-size:24px; letter-spacing:6px; color:var(--ink-muted); margin-bottom:8px; }
  .dict-hint { font-size:12px; color:var(--ink-muted); margin-bottom:20px; }
  .play-btn {
    width:60px; height:60px; border-radius:50%; border:none;
    background:var(--terracotta); color:white; font-size:22px;
    cursor:pointer; display:flex; align-items:center; justify-content:center;
    margin:0 auto 20px; transition:all 0.2s;
  }
  .play-btn:hover { background:var(--terra-deep); transform:scale(1.05); }
  .play-btn.playing { background:var(--sage); animation:pulse 1s infinite; }
  @keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.08)} }
  .dict-input {
    width:100%; padding:13px 16px; border-radius:var(--radius-sm);
    border:1.5px solid var(--border); font-size:16px;
    font-family:'DM Sans',sans-serif; color:var(--ink);
    background:var(--cream); text-align:center; outline:none; transition:border-color 0.2s;
  }
  .dict-input:focus { border-color:var(--terracotta); }
  .dict-input.correct { border-color:var(--sage); background:var(--sage-light); }
  .dict-input.wrong { border-color:var(--coral); background:var(--coral-light); }

  /* ── SHADOWING ── */
  .shadow-card {
    background:var(--warm-white); border:1px solid var(--border);
    border-radius:var(--radius); padding:18px 20px; margin-bottom:12px;
  }
  .shadow-speaker { font-size:11px; letter-spacing:1px; text-transform:uppercase; color:var(--terracotta); margin-bottom:6px; font-weight:500; }
  .shadow-en { font-family:'Playfair Display',serif; font-size:18px; color:var(--ink); margin-bottom:4px; line-height:1.4; }
  .shadow-vn { font-size:13px; color:var(--ink-muted); font-style:italic; margin-bottom:12px; }
  .shadow-btns { display:flex; gap:8px; }
  .shadow-btn {
    flex:1; padding:9px 12px; border-radius:var(--radius-sm);
    border:1px solid var(--border); background:var(--warm-white);
    font-size:12px; font-family:'DM Sans',sans-serif;
    cursor:pointer; transition:all 0.2s; color:var(--ink-soft);
    display:flex; align-items:center; justify-content:center; gap:5px;
  }
  .shadow-btn:hover { background:var(--blush); }
  .shadow-btn.primary { background:var(--terracotta); color:white; border-color:var(--terracotta); }
  .shadow-btn.primary:hover { background:var(--terra-deep); }

  /* ── PRONUNCIATION RECORDER ── */
  .rec-zone { margin-top:12px; border-top:1px solid var(--border); padding-top:12px; }
  .rec-row { display:flex; align-items:center; gap:10px; margin-bottom:10px; }
  .rec-btn {
    width:44px; height:44px; border-radius:50%; border:none;
    background:var(--blush); color:var(--terracotta);
    font-size:18px; cursor:pointer; transition:all 0.25s;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .rec-btn:hover { background:var(--rose); }
  .rec-btn.recording { background:var(--coral); color:white; animation:rec-pulse 1s infinite; }
  @keyframes rec-pulse { 0%,100%{box-shadow:0 0 0 0 rgba(232,133,106,0.5)} 50%{box-shadow:0 0 0 8px rgba(232,133,106,0)} }
  .rec-label { font-size:12px; color:var(--ink-muted); }
  .rec-label strong { color:var(--ink-soft); }
  .playback-btn {
    padding:6px 14px; border-radius:99px; border:1px solid var(--border);
    background:var(--warm-white); font-size:12px; color:var(--ink-muted);
    cursor:pointer; font-family:'DM Sans',sans-serif; transition:all 0.2s;
    display:none;
  }
  .playback-btn.show { display:inline-flex; align-items:center; gap:5px; }
  .playback-btn:hover { background:var(--blush); }

  /* Score badge */
  .score-badge { display:none; margin-top:10px; padding:12px 16px; border-radius:var(--radius-sm); font-size:13px; line-height:1.6; }
  .score-badge.show { display:block; }
  .score-badge.excellent { background:#EAF3DE; border:1px solid #7A9E87; color:#27500A; }
  .score-badge.good      { background:var(--sunny-light); border:1px solid var(--sunny); color:#7A5A00; }
  .score-badge.ok        { background:var(--sky-light); border:1px solid var(--sky); color:#185FA5; }
  .score-badge.retry     { background:var(--coral-light); border:1px solid var(--coral); color:#7A2E1A; }
  .score-bar-wrap { height:6px; background:rgba(44,36,22,0.1); border-radius:99px; margin:8px 0 4px; overflow:hidden; }
  .score-bar { height:100%; border-radius:99px; transition:width 0.6s ease; }
  .score-bar.excellent { background:#639922; }
  .score-bar.good      { background:var(--sunny); }
  .score-bar.ok        { background:var(--sky); }
  .score-bar.retry     { background:var(--coral); }
  .score-words { display:flex; flex-wrap:wrap; gap:5px; margin-top:8px; }
  .score-word { padding:2px 8px; border-radius:99px; font-size:12px; font-family:'DM Mono',monospace; }
  .score-word.hit  { background:var(--sage-light); color:var(--sage-deep); }
  .score-word.miss { background:var(--coral-light); color:#7A2E1A; }

  /* ── DONE BANNER ── */
  .done-banner {
    background:var(--sage-light); border:1px solid var(--sage);
    border-radius:var(--radius); padding:20px; text-align:center; margin-bottom:16px;
    display:none;
  }
  .done-banner.show { display:block; }
  .done-banner-title { font-family:'Playfair Display',serif; font-size:20px; color:var(--sage-deep); margin-bottom:6px; }
  .done-banner-sub { font-size:13px; color:var(--sage-deep); }
  .finish-btn {
    width:100%; padding:14px; border-radius:99px; border:none;
    background:var(--terracotta); color:white;
    font-size:15px; font-family:'DM Sans',sans-serif; font-weight:500;
    cursor:pointer; transition:all 0.2s; margin-top:8px;
  }
  .finish-btn:hover { background:var(--terra-deep); transform:translateY(-2px); }
  .section-note { font-size:12px; color:var(--ink-muted); text-align:center; margin-bottom:14px; font-style:italic; }

  /* ── FULL SCRIPT ── */
  #panel-fullscript { display:none; }
  #panel-fullscript.active { display:block; }
  .fullscript-hero { background:var(--warm-white); padding:24px 20px 20px; border-bottom:1px solid var(--border); }
  .fullscript-hero-eyebrow { font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--terracotta); margin-bottom:6px; }
  .fullscript-hero-title { font-family:'Playfair Display',serif; font-size:22px; color:var(--ink); margin-bottom:4px; }
  .fullscript-hero-sub { font-size:13px; color:var(--ink-muted); }
  .fullscript-content { padding:20px; }
  .fs-day-block { background:var(--warm-white); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; margin-bottom:16px; }
  .fs-day-header { padding:14px 18px 12px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:12px; cursor:pointer; transition:background 0.2s; user-select:none; }
  .fs-day-header:hover { background:var(--blush); }
  .fs-day-num { width:36px; height:36px; border-radius:50%; flex-shrink:0; background:var(--blush); border:1px solid var(--rose); display:flex; align-items:center; justify-content:center; font-family:'Playfair Display',serif; font-size:15px; color:var(--terracotta); }
  .fs-day-num.done-num { background:var(--sage-light); border-color:var(--sage); color:var(--sage-deep); }
  .fs-day-info { flex:1; }
  .fs-day-label { font-size:11px; letter-spacing:1px; text-transform:uppercase; color:var(--ink-muted); }
  .fs-day-title { font-size:15px; font-weight:500; color:var(--ink); margin-top:2px; }
  .fs-chevron { font-size:12px; color:var(--ink-muted); transition:transform 0.2s; }
  .fs-chevron.open { transform:rotate(90deg); }
  .fs-dialogue { padding:0 18px; max-height:0; overflow:hidden; transition:max-height 0.35s ease, padding 0.2s; }
  .fs-dialogue.open { max-height:600px; padding:14px 18px 16px; }
  .fs-line { margin-bottom:12px; padding-bottom:12px; border-bottom:1px solid var(--border); }
  .fs-line:last-child { border-bottom:none; margin-bottom:0; padding-bottom:0; }
  .fs-speaker { font-size:10px; letter-spacing:1.5px; text-transform:uppercase; color:var(--terracotta); font-weight:500; margin-bottom:4px; }
  .fs-en { font-family:'Playfair Display',serif; font-size:17px; color:var(--ink); line-height:1.4; margin-bottom:3px; }
  .fs-vn { font-size:13px; color:var(--ink-muted); font-style:italic; margin-bottom:6px; }
  .fs-line-btns { display:flex; gap:6px; flex-wrap:wrap; }
  .fs-speak-btn { padding:4px 12px; border-radius:99px; border:1px solid var(--border); background:var(--warm-white); font-size:11px; color:var(--ink-muted); cursor:pointer; font-family:'DM Sans',sans-serif; transition:all 0.2s; }
  .fs-speak-btn:hover { background:var(--blush); }
  .fs-speak-btn.slow { color:var(--sage-deep); border-color:var(--sage); }
  .fullscript-print-btn { width:100%; padding:13px; border-radius:99px; border:1.5px solid var(--terracotta); background:transparent; color:var(--terracotta); font-size:14px; font-family:'DM Sans',sans-serif; font-weight:500; cursor:pointer; transition:all 0.2s; margin-top:4px; }
  .fullscript-print-btn:hover { background:var(--blush); }
  .fs-pill { flex-shrink:0; padding:0 14px; height:44px; border-radius:22px; border:1px solid var(--border); background:var(--warm-white); font-size:12px; font-weight:500; cursor:pointer; transition:all 0.2s; display:flex; align-items:center; gap:5px; font-family:'DM Sans',sans-serif; color:var(--ink-muted); white-space:nowrap; }
  .fs-pill:hover { background:var(--blush); border-color:var(--rose); }
  .fs-pill.active { background:var(--terracotta); color:white; border-color:var(--terracotta); }

  @media print {
    header, .days-nav, .topic-hero, .day-panel, .mode-tabs,
    .fullscript-print-btn, .fs-speak-btn, .fs-day-header .fs-chevron { display:none !important; }
    #panel-fullscript { display:block !important; }
