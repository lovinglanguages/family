function renderQuizQuestion(i) {
  const qs = DAYS[i].quiz;
  const state = quizState[i];
  if (state.idx >= qs.length) {
    document.getElementById(`quiz-body-${i}`).innerHTML = `
      <div class="done-banner show">
        <div class="done-banner-title">🎉 Hoàn thành Quiz!</div>
        <div class="done-banner-sub">Bạn đã trả lời hết ${qs.length} câu. Tiếp tục với Dictation nhé!</div>
      </div>
      <button class="finish-btn" onclick="switchMode(${i},'dictation',document.querySelector('#panel-${i} .mode-tab:nth-child(4)'))">Tiếp tục Dictation →</button>`;
    return;
  }
  const q = qs[state.idx];
  state.answered = false;
  document.getElementById(`quiz-body-${i}`).innerHTML = `
    <div class="quiz-q-card">
      <div class="quiz-q-num">Câu ${state.idx + 1} / ${qs.length}</div>
      <div class="quiz-q-text">${q.q}</div>
      <div class="quiz-q-inst">Chọn đáp án đúng</div>
    </div>
    <div class="quiz-opts">
      ${q.opts.map((o, oi) => `<button class="quiz-opt" onclick="selectQuiz(${i},${oi})">${o}</button>`).join('')}
    </div>
    <div class="quiz-fb" id="qfb-${i}"></div>
    <button class="quiz-next" id="qnext-${i}" onclick="nextQuiz(${i})" disabled>Câu tiếp theo →</button>`;
}

function selectQuiz(i, chosen) {
  const state = quizState[i];
  if (state.answered) return;
  state.answered = true;
  const q = DAYS[i].quiz[state.idx];
  const opts = document.querySelectorAll(`#panel-${i} .quiz-opt`);
  opts.forEach((o, oi) => { if (oi === q.ans) o.classList.add('correct'); });
  const fb = document.getElementById(`qfb-${i}`);
  if (chosen === q.ans) {
    opts[chosen].classList.add('correct');
    fb.textContent = '🎉 Chính xác! ' + q.exp;
    fb.className = 'quiz-fb ok show';
  } else {
    opts[chosen].classList.add('wrong');
    fb.textContent = '❌ Chưa đúng. ' + q.exp;
    fb.className = 'quiz-fb nope show';
  }
  document.getElementById(`qnext-${i}`).disabled = false;
}

function nextQuiz(i) {
  quizState[i].idx++;
  renderQuizQuestion(i);
}

// ═══════════════════════════════════════════════════════
//  DICTATION
// ═══════════════════════════════════════════════════════
function renderDict(i) {
  dictState[i] = { idx: 0, playing: false };
  renderDictItem(i);
}

function renderDictItem(i) {
  const items = DAYS[i].dictation;
  const state = dictState[i];
  if (state.idx >= items.length) {
    document.getElementById(`dict-body-${i}`).innerHTML = `
      <div class="done-banner show">
        <div class="done-banner-title">✍️ Dictation xong rồi!</div>
        <div class="done-banner-sub">Tuyệt! Giờ thực hành Shadowing cùng con nhé!</div>
      </div>
      <button class="finish-btn" onclick="switchMode(${i},'shadowing',document.querySelector('#panel-${i} .mode-tab:nth-child(5)'))">Tiếp tục Shadowing →</button>`;
    return;
  }
  const item = items[state.idx];
  state.playing = false;
  document.getElementById(`dict-body-${i}`).innerHTML = `
    <p class="section-note">Nghe và gõ lại từ bạn nghe được 👂 (${state.idx + 1}/${items.length})</p>
    <div class="dict-card">
      <div class="dict-blanks">${item.text.replace(/[^\s]/g, '_')}</div>
      <div class="dict-hint">${item.hint}<br><em>${item.hintVn}</em></div>
      <button class="play-btn" id="dplay-${i}" onclick="playDict(${i})">▶</button>
      <input class="dict-input" id="dinput-${i}" type="text" placeholder="Gõ từ bạn nghe..."
        oninput="checkDict(${i})" autocomplete="off" autocorrect="off" spellcheck="false">
    </div>
    <div class="quiz-fb" id="dfb-${i}"></div>
    <button class="quiz-next" id="dnext-${i}" onclick="nextDict(${i})" disabled>Từ tiếp theo →</button>`;
}

function playDict(i) {
  const item = DAYS[i].dictation[dictState[i].idx];
  const btn = document.getElementById(`dplay-${i}`);
  btn.classList.add('playing');
  speak(item.text, 0.75);
  setTimeout(() => btn.classList.remove('playing'), 2000);
}

function checkDict(i) {
  const item = DAYS[i].dictation[dictState[i].idx];
  const inp = document.getElementById(`dinput-${i}`);
  const val = inp.value.trim().toLowerCase();
  const ans = item.text.toLowerCase();
  if (!val) return;
  if (val === ans) {
    inp.className = 'dict-input correct';
    const fb = document.getElementById(`dfb-${i}`);
    fb.textContent = '🎉 Chính xác!'; fb.className = 'quiz-fb ok show';
    document.getElementById(`dnext-${i}`).disabled = false;
  } else {
    inp.className = 'dict-input';
  }
}

function nextDict(i) {
  dictState[i].idx++;
  renderDictItem(i);
}

// ═══════════════════════════════════════════════════════
//  SPEECH
// ═══════════════════════════════════════════════════════
let _selectedVoice = null;
const VOICE_PRIORITY = [
  'Google US English', 'Google UK English Female',
  'Microsoft Aria Online (Natural) - English (United States)',
  'Samantha', 'Karen', 'Google العربية',
];

function pickVoice() {
  if (_selectedVoice) return _selectedVoice;
  const voices = speechSynthesis.getVoices();
  if (!voices.length) return null;
  for (const name of VOICE_PRIORITY) {
    const v = voices.find(v => v.name === name);
    if (v) { _selectedVoice = v; return v; }
  }
  const googleFemale = voices.find(v => v.lang.startsWith('en') && v.name.toLowerCase().includes('google') && !v.name.toLowerCase().includes('male'));
  if (googleFemale) { _selectedVoice = googleFemale; return googleFemale; }
  const onlineFemale = voices.find(v => v.lang === 'en-US' && (v.name.toLowerCase().includes('female') || v.name.toLowerCase().includes('online')));
  if (onlineFemale) { _selectedVoice = onlineFemale; return onlineFemale; }
  const anyUS = voices.find(v => v.lang === 'en-US');
  if (anyUS) { _selectedVoice = anyUS; return anyUS; }
  return null;
}

if ('speechSynthesis' in window) {
  speechSynthesis.onvoiceschanged = () => { _selectedVoice = null; pickVoice(); };
}

function speak(text, rate = 0.85) {
  if (!('speechSynthesis' in window)) return;
  speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'en-US'; u.rate = rate; u.pitch = 1.0;
  const voice = pickVoice();
  if (voice) u.voice = voice;
  speechSynthesis.speak(u);
}

// ═══════════════════════════════════════════════════════
//  PRONUNCIATION RECORDER & SCORER
// ═══════════════════════════════════════════════════════
const recState = {};

function toggleRecord(id, targetText) {
  if (recState[id]?.active) stopRecord(id, targetText);
  else startRecord(id, targetText);
}

async function startRecord(id, targetText) {
  const btn    = document.getElementById(`${id}-recbtn`);
  const label = document.getElementById(`${id}-reclabel`);
  const score = document.getElementById(`${id}-score`);
  const pbk    = document.getElementById(`${id}-playbk`);
  score.className = 'score-badge';
  pbk.className   = 'playback-btn';

  let stream;
  try { stream = await navigator.mediaDevices.getUserMedia({ audio: true }); }
  catch(e) {
    label.innerHTML = '<strong style="color:var(--coral)">Không thể mở micro.</strong> Hãy cho phép trình duyệt truy cập micro.';
    return;
  }

  const mr = new MediaRecorder(stream);
  const chunks = [];
  mr.ondataavailable = e => { if (e.data.size > 0) chunks.push(e.data); };
  mr.onstop = () => {
    recState[id].blob = new Blob(chunks, { type: 'audio/webm' });
    stream.getTracks().forEach(t => t.stop());
    pbk.className = 'playback-btn show';
  };
  mr.start();

  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (SR) {
    const rec = new SR();
    rec.lang = 'en-US'; rec.continuous = false;
    rec.interimResults = false; rec.maxAlternatives = 3;
    rec.onresult = e => {
      const alts = [];
      for (let i = 0; i < e.results[0].length; i++) alts.push(e.results[0][i].transcript.toLowerCase().trim());
      recState[id].recognized = alts;
    };
    rec.onerror = () => { recState[id].recognized = []; };
    rec.start();
    recState[id] = { ...recState[id], recognition: rec };
  }

  recState[id] = { ...recState[id], mediaRecorder: mr, chunks, active: true, blob: null, recognized: [] };
  btn.classList.add('recording'); btn.textContent = '⏹';
  label.innerHTML = '<strong style="color:var(--coral)">Đang thu âm...</strong> Bấm ⏹ để dừng';
}

function stopRecord(id, targetText) {
  const state = recState[id];
  if (!state?.active) return;
  const btn    = document.getElementById(`${id}-recbtn`);
  const label = document.getElementById(`${id}-reclabel`);
  state.mediaRecorder.stop();
  try { state.recognition?.stop(); } catch(e) {}
  state.active = false;
  btn.classList.remove('recording'); btn.textContent = '🎤';
  label.innerHTML = '<strong>Đang chấm điểm...</strong>';
  setTimeout(() => scoreProunciation(id, targetText), 900);
}

function scoreProunciation(id, targetText) {
  const label  = document.getElementById(`${id}-reclabel`);
  const badge  = document.getElementById(`${id}-score`);
  const alts   = recState[id]?.recognized || [];
  const tWords = targetText.toLowerCase().replace(/[^\w\s']/g, '').trim().split(/\s+/);

  if (!alts.length) { renderScore(badge, label, 0, tWords, []); return; }

  let bestScore = 0, bestMatch = [];
  alts.forEach(alt => {
    const aWords = alt.replace(/[^\w\s']/g, '').split(/\s+/);
    const { score, matches } = wordMatchScore(tWords, aWords);
    if (score > bestScore) { bestScore = score; bestMatch = matches; }
  });
  renderScore(badge, label, bestScore, tWords, bestMatch);
}

function wordMatchScore(tWords, aWords) {
  const matches = tWords.map(tw => {
    const twn = norm(tw);
    if (aWords.some(sw => norm(sw) === twn)) return { word: tw, hit: true };
    const fuzzy = aWords.some(sw => twn.length >= 4 ? lev(twn, norm(sw)) <= 1 : norm(sw) === twn);
    return { word: tw, hit: fuzzy };
  });
  return { score: Math.round(matches.filter(m => m.hit).length / tWords.length * 100), matches };
}

function norm(w) { return w.toLowerCase().replace(/[^a-z']/g, ''); }

function lev(a, b) {
  const m = a.length, n = b.length;
  const dp = Array.from({length:m+1}, (_,i) => Array.from({length:n+1}, (_,j) => i===0?j:j===0?i:0));
  for (let i=1;i<=m;i++) for (let j=1;j<=n;j++)
    dp[i][j] = a[i-1]===b[j-1] ? dp[i-1][j-1] : 1+Math.min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1]);
  return dp[m][n];
}

function renderScore(badge, label, score, tWords, matches) {
  let tier, emoji, msg, tip;
  if (score >= 90)      { tier='excellent'; emoji='🌟'; msg=`Xuất sắc! Phát âm rất chuẩn (${score}%)!`; tip='Tuyệt vời – bé sẽ học theo giọng ba/mẹ này!'; }
  else if (score >= 70) { tier='good';      emoji='👍'; msg=`Tốt! Đúng ${score}% từ.`;                 tip='Nghe lại và lặp thêm một lần nhé!'; }
  else if (score >= 40) { tier='ok';        emoji='💪'; msg=`Cố lên! Đúng ${score}% từ.`;                tip='Nghe chậm → lặp từng từ → nói cả câu.'; }
  else                  { tier='retry';     emoji='🔄'; msg=score===0?'Chưa nhận được giọng nói. Thử lại!':`Đúng ${score}% — Hãy thử lại!`; tip='Bấm ▶ Nghe chậm rồi bắt chước từng từ.'; }

  const wordHTML = matches.length
    ? '<div class="score-words">'+matches.map(m=>`<span class="score-word ${m.hit?'hit':'miss'}">${m.word}</span>`).join('')+'</div>' : '';

  badge.className = `score-badge show ${tier}`;
  badge.innerHTML = `
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
      <span style="font-size:18px">${emoji}</span><strong>${msg}</strong>
    </div>
    <div class="score-bar-wrap"><div class="score-bar ${tier}" style="width:${score}%"></div></div>
    <div style="font-size:12px;margin-top:4px;opacity:0.8">${tip}</div>
    ${wordHTML}`;
  label.innerHTML = '<strong>Bấm mic</strong> để thử lại';
}

function playbackRec(id) {
  const blob = recState[id]?.blob;
  if (!blob) return;
  new Audio(URL.createObjectURL(blob)).play();
}

