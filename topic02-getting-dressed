async function finishDay(i, btnElement) {
  // Ẩn nút hoàn thành
  if(btnElement) btnElement.style.display = 'none';

  if (!doneDays.includes(i)) {
    doneDays.push(i);
  }
  
  // Hiện banner
  document.getElementById(`done-${i}`).classList.add('show');
  renderNav();
  document.getElementById(`done-${i}`).scrollIntoView({ behavior: 'smooth' });

  if (!currentUser) return;
  
  const currentGlobalDay = i + 1; 
  // Ghi nhận progress cho Topic 02 (index 1)
  const savedProgress = userProgress.progress[1] || 0;

  // 1. Lưu tiến độ nếu là bài mới
  if (currentGlobalDay > savedProgress) {
    userProgress.progress[1] = currentGlobalDay;
  }

  // 2. LOGIC TÍNH STREAK CHUẨN XÁC
  const today = new Date();
  today.setHours(0,0,0,0); // Đưa về 00:00:00 của ngày hôm nay
  const todayTime = today.getTime();
  const lastActiveTime = userProgress.lastActiveTime || 0;
  const oneDay = 24 * 60 * 60 * 1000; // 1 ngày tính bằng miligiây

  if (lastActiveTime === 0) {
    userProgress.streak = 1;
    userProgress.lastActiveTime = todayTime;
  } else {
    const diffDays = Math.round((todayTime - lastActiveTime) / oneDay);
    if (diffDays === 1) {
      userProgress.streak = (userProgress.streak || 0) + 1;
      userProgress.lastActiveTime = todayTime;
    } else if (diffDays > 1) {
      userProgress.streak = 1; 
      userProgress.lastActiveTime = todayTime;
    }
  }

  // Ghi lên Firebase
  await db.collection("users").doc(currentUser.uid).set(userProgress, { merge: true });
}

function renderNav() {
  const nav = document.getElementById('daysNav');
  nav.innerHTML = '';
  DAYS.forEach((d, i) => {
    const globalDay = TOPIC.startDay + i;
    const isDone = doneDays.includes(i);
    const isActive = i === currentDay && currentView === 'day';
    const cls = isActive ? 'day-pill active' : isDone ? 'day-pill done' : 'day-pill';
    nav.innerHTML += `<button class="${cls}" onclick="openDay(${i})">
      <span class="day-pill-num">${globalDay}</span>
      ${isDone && !isActive ? '<span class="day-pill-check">✓</span>' : ''}
    </button>`;
  });
  const fsActive = currentView === 'fullscript';
  nav.innerHTML += `<button class="fs-pill${fsActive ? ' active' : ''}" onclick="openFullScript()">📜 Full Script</button>`;
}

